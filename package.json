{
  "name": "vaptdoc",
  "version": "1.0.0",
  "private": true,
  "description": "Conversor full-stack de arquivos com OCR, foco em seguranca e deploy rapido.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node scripts/build-assets.mjs && tsup src/server.ts --format esm --outDir dist --sourcemap",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run --pool=threads",
    "smoke:public": "node scripts/smoke-public.mjs",
    "backup:create": "node scripts/backup-data.mjs",
    "backup:verify": "node scripts/verify-backup.mjs",
    "backup:restore": "node scripts/restore-backup.mjs"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/static": "^9.1.3",
    "@ilovepdf/ilovepdf-nodejs": "^0.3.1",
    "aspose.3d": "^26.2.0",
    "convertapi": "^1.15.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ffmpeg-static": "^5.3.0",
    "file-type": "^22.0.1",
    "nodemailer": "^7.0.10",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "sanitize-filename": "^1.6.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
